<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_alter().
 * Adds custom validation to ALL node forms.
 */
function wcag_helper_form_alter(&$form, FormStateInterface $form_state, $form_id) {

  // Only target node forms (CORRECTED CONDITION)
  if (strpos($form_id, 'node_') === 0 && strpos($form_id, '_form') !== FALSE) {

    // Attach JS library
    $form['#attached']['library'][] = 'wcag_helper/ckeditor_watcher';

    // Attach custom validator
    $form['#validate'][] = 'wcag_helper_node_form_validate';
  }
}

/**
 * Custom validation for node forms.
 */
function wcag_helper_node_form_validate(&$form, FormStateInterface $form_state) {

  // Load service
  $rule = \Drupal::service('wcag_helper.alt_text_rule');

  if (!$rule) {
    \Drupal::logger('wcag_helper')->error('Alt text rule service not found.');
    return;
  }

  // Get submitted values
  $values = $form_state->getValues();
  $issues_found = [];

  // -------------------------
  // PART A: Image field check
  // -------------------------
  foreach ($values as $field_name => $value) {

    if (!is_array($value)) {
      continue;
    }

    foreach ($value as $item) {

      if (is_array($item) && isset($item['alt'])) {

        $issues = $rule->check([
          'images' => [$item]
        ]);

        if (!empty($issues)) {
          $issues_found[] = $field_name;

          $form_state->setErrorByName(
            $field_name,
            t('Image alt text is required for accessibility (WCAG 1.1.1). Please add alt text.')
          );

          break;
        }
      }
    }
  }

  // -------------------------
  // PART B: CKEditor body check
  // -------------------------

  $body_html = '';

  if (isset($values['body'][0]['value'])) {
    $body_html = $values['body'][0]['value'];
  }

  if (!empty($body_html)) {
    $dom = new \DOMDocument();

    // Better error handling (instead of @)
    libxml_use_internal_errors(TRUE);
    $dom->loadHTML(mb_convert_encoding($body_html, 'HTML-ENTITIES', 'UTF-8'));
    libxml_clear_errors();

    $images = $dom->getElementsByTagName('img');

    foreach ($images as $img) {
      if (!$img->hasAttribute('alt') || trim($img->getAttribute('alt')) === '') {

        $issues_found[] = 'body';

        $form_state->setErrorByName(
          'body',
          t('One or more images in the Body field are missing alt text.')
        );

        break;
      }
    }
  }

  // -------------------------
  // LOGGING
  // -------------------------
  if (!empty($issues_found)) {
    \Drupal::logger('wcag_helper')->warning(
      'WCAG validation failed in fields: @fields',
      ['@fields' => implode(', ', $issues_found)]
    );
  }
}